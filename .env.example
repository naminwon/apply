# Apps Script Web App URL
# 배포 후 발급받은 URL을 입력
VITE_API_URL=https://script.google.com/macros/s/PASTE-YOUR-DEPLOYMENT-ID/exec

# API 토큰 (Apps Script와 동일하게 설정)
VITE_API_TOKEN=codnut-apply-dashboard-1984-1592

# Mock 데이터 사용 여부
# true: mock-data/api-response.json 사용 (개발 초기)
# false: 실제 API 호출
VITE_USE_MOCK=true
